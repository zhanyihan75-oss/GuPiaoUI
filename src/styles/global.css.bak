
/* === Skill Stickers === */
.sticker {
  position: absolute; padding: 0.5rem 1rem;
  border-radius: var(--radius-sm); font-size: 0.8rem;
  font-weight: 600; color: white;
  white-space: nowrap; box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  z-index: 3; pointer-events: none;
}
.sticker-1 { background: var(--color-mint); color: #111; top: 12%; right: 8%; transform: rotate(-5deg); }
.sticker-2 { background: var(--color-accent-c); top: 18%; left: 6%; transform: rotate(3deg); }
.sticker-3 { background: var(--color-accent-b); color: #111; bottom: 25%; right: 5%; transform: rotate(-2deg); }
.sticker-4 { background: var(--color-violet); bottom: 30%; left: 8%; transform: rotate(7deg); }
.sticker-5 { background: var(--color-accent-a); top: 40%; right: 3%; transform: rotate(-4deg); }
.sticker-6 { background: var(--color-orange); top: 35%; left: 3%; transform: rotate(5deg); }


/* === Works Scroll === */
.works-scroll {
  padding: 4rem 0 5rem; overflow: visible;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
.works-scroll .section-title { margin-left: 2rem; }
.works-container {
  display: flex; gap: 24px; width: max-content;
  animation: scrollWorks 25s linear infinite;
  padding: 0 2rem;
}
.works-container.paused { animation-play-state: paused; }
.work-card {
  width: 220px; height: 140px; background: white;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; font-weight: 600; color: var(--color-text);
  cursor: pointer; transition: all 0.3s ease;
  position: relative; overflow: visible;
}
.work-card::before {
  content: ""; position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--color-accent-a), var(--color-accent-c));
  opacity: 0; transition: opacity 0.3s ease;
}
.work-card:hover::before { opacity: 1; }
.work-card:hover {
  border-color: transparent; transform: scale(1.05);
  box-shadow: 0 8px 30px rgba(0,0,0,0.12);
}
.work-card:hover .card-title { color: white; position: relative; z-index: 1; }
.card-title { position: relative; z-index: 1; transition: color 0.3s ease; }
@keyframes scrollWorks { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }


/* === Contact Section === */
.contact-section {
  padding: 6rem 2rem; max-width: 800px;
  margin: 0 auto; text-align: center;
}
.contact-content { margin-top: 2rem; }
.contact-text { font-size: 1.25rem; color: var(--color-text-secondary); margin-bottom: 1.5rem; }
.contact-email {
  display: inline-block; font-size: 1.5rem; font-weight: 600;
  font-family: var(--font-heading); color: var(--color-accent-a);
  border-bottom: 2px solid var(--color-accent-a);
  padding-bottom: 4px; transition: all 0.3s ease;
}
.contact-email:hover { color: var(--color-accent-c); border-color: var(--color-accent-c); }
.contact-socials { display: flex; justify-content: center; gap: 2rem; margin-top: 2.5rem; }
.social-link {
  font-size: 0.9rem; font-weight: 500;
  color: var(--color-text-secondary);
  padding: 8px 16px; border: 1px solid rgba(0,0,0,0.1);
  border-radius: var(--radius-pill); transition: all 0.3s ease;
}
.social-link:hover { background: var(--color-text); color: white; border-color: var(--color-text); }


/* === Footer === */
.footer {
  text-align: center; padding: 3rem 2rem;
  color: var(--color-text-secondary); font-size: 0.85rem;
  border-top: 1px solid rgba(0,0,0,0.06);
}


/* === Responsive === */
@media (max-width: 768px) {
  .navbar { padding: 1rem 1.25rem; }
  .hero-content { margin-left: 24px; }
  .hero-nav { left: 24px; bottom: 40px; }
  .about-section { padding: 4rem 1.25rem 3rem; }
  .about-grid { flex-direction: column; gap: 1.5rem; }
  .about-photo-wrapper { margin-bottom: 1rem; }
  .about-photo-placeholder { width: 120px; height: 120px; }
  .about-card { transform: rotate(0deg) !important; }
  .sticker { display: none; }
  .work-card { width: 180px; height: 110px; }
  .contact-email { font-size: 1.1rem; }
  .contact-socials { flex-wrap: wrap; gap: 0.75rem; }


/* === Mobile Nav Toggle === */
@media (max-width: 768px) {
  .logo-text {
    display: none;
  }
  .nav-toggle {
    display: flex;
  }
  .nav-cards {
    flex-direction: column;
  }
  .nav-card {
    min-height: auto;
  }
}}







