<!-- INTERACTIONS SCRIPT -->
<script>
  // Works scroll pause
  const track = document.getElementById("worksTrack");
  if (track) {
    track.addEventListener("mouseenter", () => track.classList.add("paused"));
    track.addEventListener("mouseleave", () => track.classList.remove("paused"));
  }

  // Hamburger toggle
  const toggle = document.querySelector(".nav-toggle");
  const cards = document.getElementById("navCards");
  if (toggle && cards) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle.classList.toggle("active");
      cards.classList.toggle("open");
    });
    // Click outside to close
    document.addEventListener("click", (e) => {
      if (!toggle.contains(e.target) && !cards.contains(e.target) && cards.classList.contains("open")) {
        toggle.classList.remove("active");
        cards.classList.remove("open");
      }
    });
  }
</script>
